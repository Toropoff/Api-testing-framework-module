{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrderResponse",
  "type": "object",
  "required": ["id", "userId", "sku", "quantity", "status"],
  "properties": {
    "id": {
      "type": "integer"
    },
    "userId": {
      "type": "integer"
    },
    "sku": {
      "type": "string"
    },
    "quantity": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string"
    }
  }
}
