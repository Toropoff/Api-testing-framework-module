<!--
    LTW configuration for the vendored AllureAspectJ.

    No <include within> restriction is applied here — the original allure-assertj aop-ajc.xml
    also has none. Adding <include within="org.assertj.core.api..*"/> would prevent AspectJ from
    weaving into our custom assertion subclasses (e.g. AbstractApiResponseAssert, HolidayByDateAssert)
    because their methods are declared outside the assertj package, breaking auto-step generation
    for the fluent DSL.

    Weaver options suppress AspectJ advice-lint warnings that are expected and harmless for
    Load-Time Weaving — matching the behaviour of the original aop-ajc.xml.
-->
<aspectj>
    <weaver options="-warn:none -Xlint:ignore"/>
    <aspects>
        <aspect name="io.qameta.allure.assertj.AllureAspectJ"/>
    </aspects>
</aspectj>
