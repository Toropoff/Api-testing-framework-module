<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Smoke Suite" verbose="1">
    <listeners>
        <listener class-name="com.apiframework.testng.retry.RetryAnnotationTransformer"/>
        <listener class-name="com.apiframework.testng.retry.RetryReportingListener"/>
        <listener class-name="com.apiframework.reporting.allure.AllureTestNgListener"/>
    </listeners>
    <test name="Smoke API Tests">
        <classes>
            <class name="com.apiframework.tests.smoke.UserSmokeTest"/>
            <class name="com.apiframework.tests.smoke.GoogleSearchSmokeTest"/>
        </classes>
    </test>
</suite>
